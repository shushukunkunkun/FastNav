<?xml version="1.0" encoding="UTF-8"?>

<sdf version="1.9">
  <model name="x250_mid360">
    <!--
      FastNav x250_mid360.

      Design target:
      - diagonal motor-to-motor wheelbase: about 250 mm
      - rotor center coordinate: a = 0.0884 m, so wheelbase is
        $2 sqrt(2) a = 0.250 m$
      - total mass: about 0.765 kg with the Mid360 link

      The model intentionally uses primitive boxes/cylinders instead of mesh
      assets, so the physical size, collision volume and inertia are easy to
      inspect and tune.
    -->
    <pose>0 0 0.14 0 0 0</pose>
    <self_collide>false</self_collide>
    <static>false</static>

    <link name="base_link">
      <inertial>
        <mass>0.45</mass>
        <inertia>
          <ixx>0.0038</ixx>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyy>0.0038</iyy>
          <iyz>0.0</iyz>
          <izz>0.0068</izz>
        </inertia>
      </inertial>
      <gravity>true</gravity>
      <velocity_decay />

      <visual name="body_visual">
        <geometry>
          <box>
            <size>0.11 0.09 0.035</size>
          </box>
        </geometry>
        <material>
          <ambient>0.02 0.02 0.02 1.0</ambient>
          <diffuse>0.08 0.08 0.08 1.0</diffuse>
          <specular>0.2 0.2 0.2 1.0</specular>
        </material>
      </visual>
      <collision name="body_collision">
        <geometry>
          <box>
            <size>0.11 0.09 0.035</size>
          </box>
        </geometry>
      </collision>

      <visual name="arm_forward_left_backward_right">
        <pose>0 0 0 0 0 0.7853981634</pose>
        <geometry>
          <box>
            <size>0.255 0.018 0.014</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.18 0.18 0.18 1.0</diffuse>
        </material>
      </visual>
      <collision name="arm_forward_left_backward_right_collision">
        <pose>0 0 0 0 0 0.7853981634</pose>
        <geometry>
          <box>
            <size>0.255 0.018 0.014</size>
          </box>
        </geometry>
      </collision>

      <visual name="arm_forward_right_backward_left">
        <pose>0 0 0 0 0 -0.7853981634</pose>
        <geometry>
          <box>
            <size>0.255 0.018 0.014</size>
          </box>
        </geometry>
        <material>
          <ambient>0.1 0.1 0.1 1.0</ambient>
          <diffuse>0.18 0.18 0.18 1.0</diffuse>
        </material>
      </visual>
      <collision name="arm_forward_right_backward_left_collision">
        <pose>0 0 0 0 0 -0.7853981634</pose>
        <geometry>
          <box>
            <size>0.255 0.018 0.014</size>
          </box>
        </geometry>
      </collision>

      <sensor name="air_pressure_sensor" type="air_pressure">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>50</update_rate>
        <air_pressure>
          <pressure>
            <noise type="gaussian">
              <mean>0</mean>
              <stddev>3</stddev>
            </noise>
          </pressure>
        </air_pressure>
      </sensor>

      <sensor name="magnetometer_sensor" type="magnetometer">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>100</update_rate>
        <magnetometer>
          <x><noise type="gaussian"><stddev>0.0001</stddev></noise></x>
          <y><noise type="gaussian"><stddev>0.0001</stddev></noise></y>
          <z><noise type="gaussian"><stddev>0.0001</stddev></noise></z>
        </magnetometer>
      </sensor>

      <sensor name="imu_sensor" type="imu">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>250</update_rate>
        <imu>
          <angular_velocity>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.0008726646</stddev></noise></z>
          </angular_velocity>
          <linear_acceleration>
            <x><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></x>
            <y><noise type="gaussian"><mean>0.0</mean><stddev>0.00637</stddev></noise></y>
            <z><noise type="gaussian"><mean>0.0</mean><stddev>0.00686</stddev></noise></z>
          </linear_acceleration>
        </imu>
      </sensor>

      <sensor name="navsat_sensor" type="navsat">
        <gz_frame_id>base_link</gz_frame_id>
        <always_on>1</always_on>
        <update_rate>30</update_rate>
      </sensor>
    </link>

    <link name="rotor_0">
      <pose>0.0884 -0.0884 0.030 0 0 0</pose>
      <inertial>
        <mass>0.012</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
        </inertia>
      </inertial>
      <visual name="motor_visual">
        <geometry><cylinder><radius>0.018</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.03 0.03 0.03 1</ambient><diffuse>0.03 0.03 0.03 1</diffuse></material>
      </visual>
      <visual name="prop_visual">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
        <material><ambient>0.02 0.02 0.02 0.45</ambient><diffuse>0.02 0.02 0.02 0.45</diffuse></material>
      </visual>
      <collision name="prop_collision">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>

    <link name="rotor_1">
      <pose>-0.0884 0.0884 0.030 0 0 0</pose>
      <inertial>
        <mass>0.012</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
        </inertia>
      </inertial>
      <visual name="motor_visual">
        <geometry><cylinder><radius>0.018</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.03 0.03 0.03 1</ambient><diffuse>0.03 0.03 0.03 1</diffuse></material>
      </visual>
      <visual name="prop_visual">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
        <material><ambient>0.02 0.02 0.02 0.45</ambient><diffuse>0.02 0.02 0.02 0.45</diffuse></material>
      </visual>
      <collision name="prop_collision">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>

    <link name="rotor_2">
      <pose>0.0884 0.0884 0.030 0 0 0</pose>
      <inertial>
        <mass>0.012</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
        </inertia>
      </inertial>
      <visual name="motor_visual">
        <geometry><cylinder><radius>0.018</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.03 0.03 0.03 1</ambient><diffuse>0.03 0.03 0.03 1</diffuse></material>
      </visual>
      <visual name="prop_visual">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
        <material><ambient>0.02 0.02 0.02 0.45</ambient><diffuse>0.02 0.02 0.02 0.45</diffuse></material>
      </visual>
      <collision name="prop_collision">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>

    <link name="rotor_3">
      <pose>-0.0884 -0.0884 0.030 0 0 0</pose>
      <inertial>
        <mass>0.012</mass>
        <inertia>
          <ixx>1.0e-5</ixx>
          <iyy>1.0e-5</iyy>
          <izz>2.0e-5</izz>
        </inertia>
      </inertial>
      <visual name="motor_visual">
        <geometry><cylinder><radius>0.018</radius><length>0.018</length></cylinder></geometry>
        <material><ambient>0.03 0.03 0.03 1</ambient><diffuse>0.03 0.03 0.03 1</diffuse></material>
      </visual>
      <visual name="prop_visual">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
        <material><ambient>0.02 0.02 0.02 0.45</ambient><diffuse>0.02 0.02 0.02 0.45</diffuse></material>
      </visual>
      <collision name="prop_collision">
        <geometry><cylinder><radius>0.063</radius><length>0.002</length></cylinder></geometry>
      </collision>
    </link>

    <joint name="rotor_0_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_0</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <joint name="rotor_1_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_1</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <joint name="rotor_2_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_2</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>
    <joint name="rotor_3_joint" type="revolute">
      <parent>base_link</parent>
      <child>rotor_3</child>
      <axis><xyz>0 0 1</xyz><limit><lower>-1e+16</lower><upper>1e+16</upper></limit></axis>
    </joint>

    <link name="mid360_link">
      <pose relative_to="base_link">0.0 0.0 0.090 0 0 0</pose>
      <inertial>
        <mass>0.265</mass>
        <inertia>
          <ixx>0.0004</ixx>
          <iyy>0.0004</iyy>
          <izz>0.0004</izz>
          <ixy>0.0</ixy>
          <ixz>0.0</ixz>
          <iyz>0.0</iyz>
        </inertia>
      </inertial>
      <visual name="mid360_visual">
        <geometry><cylinder><radius>0.035</radius><length>0.045</length></cylinder></geometry>
        <material><ambient>0.05 0.05 0.05 1</ambient><diffuse>0.05 0.05 0.05 1</diffuse></material>
      </visual>
      <collision name="mid360_collision">
        <geometry><cylinder><radius>0.035</radius><length>0.045</length></cylinder></geometry>
      </collision>
      <sensor name="mid360_lidar" type="gpu_lidar">
        <pose>0 0 0 0 0 0</pose>
        <topic>mid360/points</topic>
        <update_rate>10</update_rate>
        <always_on>true</always_on>
        <visualize>true</visualize>
        <ray>
          <scan>
            <horizontal>
              <samples>720</samples>
              <resolution>1</resolution>
              <min_angle>-3.141592653589793</min_angle>
              <max_angle>3.141592653589793</max_angle>
            </horizontal>
            <vertical>
              <samples>64</samples>
              <resolution>1</resolution>
              <min_angle>-0.1221730476</min_angle>
              <max_angle>0.9075712110</max_angle>
            </vertical>
          </scan>
          <range>
            <min>0.1</min>
            <max>40.0</max>
            <resolution>0.01</resolution>
          </range>
          <noise>
            <type>gaussian</type>
            <mean>0.0</mean>
            <stddev>0.01</stddev>
          </noise>
        </ray>
      </sensor>
    </link>

    <joint name="mid360_joint" type="fixed">
      <parent>base_link</parent>
      <child>mid360_link</child>
      <pose relative_to="base_link">0.0 0.0 0.090 0 0 0</pose>
    </joint>

    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_0_joint</jointName>
      <linkName>rotor_0</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100.0</maxRotVelocity>
      <motorConstant>2.50e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>0</motorNumber>
      <rotorDragCoefficient>3.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>5.0e-07</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_1_joint</jointName>
      <linkName>rotor_1</linkName>
      <turningDirection>ccw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100.0</maxRotVelocity>
      <motorConstant>2.50e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>1</motorNumber>
      <rotorDragCoefficient>3.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>5.0e-07</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_2_joint</jointName>
      <linkName>rotor_2</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100.0</maxRotVelocity>
      <motorConstant>2.50e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>2</motorNumber>
      <rotorDragCoefficient>3.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>5.0e-07</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>
    <plugin filename="gz-sim-multicopter-motor-model-system"
      name="gz::sim::systems::MulticopterMotorModel">
      <jointName>rotor_3_joint</jointName>
      <linkName>rotor_3</linkName>
      <turningDirection>cw</turningDirection>
      <timeConstantUp>0.0125</timeConstantUp>
      <timeConstantDown>0.025</timeConstantDown>
      <maxRotVelocity>1100.0</maxRotVelocity>
      <motorConstant>2.50e-06</motorConstant>
      <momentConstant>0.016</momentConstant>
      <commandSubTopic>command/motor_speed</commandSubTopic>
      <motorNumber>3</motorNumber>
      <rotorDragCoefficient>3.0e-05</rotorDragCoefficient>
      <rollingMomentCoefficient>5.0e-07</rollingMomentCoefficient>
      <rotorVelocitySlowdownSim>10</rotorVelocitySlowdownSim>
      <motorType>velocity</motorType>
    </plugin>

    <plugin filename="gz-sim-odometry-publisher-system"
      name="gz::sim::systems::OdometryPublisher">
      <dimensions>3</dimensions>
    </plugin>

    <plugin filename="MotorFailurePlugin"
      name="gz::sim::systems::MotorFailureSystem">
    </plugin>
  </model>
</sdf>
