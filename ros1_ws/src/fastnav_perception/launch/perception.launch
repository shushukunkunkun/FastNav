<launch>
    <arg name="config_file" default="$(find fastnav_bringup)/../../../config/sim/perception.yaml"/>

    <!-- 加载项目顶层感知参数：转换节点使用 $p_o = R p_l + t$，滤波节点使用距离约束 $r_min <= ||p - s|| <= r_max$。 -->
    <rosparam file="$(arg config_file)"
              command="load"/>

    <!-- cloud_transform_node 将 /fastnav/lidar/points 从 mid360_link 转换到 odom，输出 $frame_id = odom$。 -->
    <node pkg="fastnav_perception"
          type="cloud_transform_node"
          name="cloud_transform_node"
          output="screen"/>

    <!-- cloud_filter_node 对 odom 点云执行 NaN 去除、距离裁剪、空间裁剪和 VoxelGrid 降采样。 -->
    <node pkg="fastnav_perception"
          type="cloud_filter_node"
          name="cloud_filter_node"
          output="screen"/>
</launch>
