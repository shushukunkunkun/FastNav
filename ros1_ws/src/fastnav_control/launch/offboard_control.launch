<!--
    ROS1 launch 文件用于描述一组需要一起启动的资源，例如参数、节点、命名空间和子 launch 文件。
    本文件是 FastNav offboard 控制模块的启动入口：先加载控制器参数，再启动 offboard 控制节点。
    它通常会被 fastnav_bringup/launch/sim_offboard.launch 通过 <include> 引入。
-->
<launch>
    <!-- <launch> 是 launch 文件的根标签，所有 <rosparam>、<node>、<include> 等标签都必须写在它内部。 -->
    <arg name="config_file" default="$(find fastnav_bringup)/../../../config/sim/controller.yaml"/>

    <!--
        控制参数统一放在项目顶层 config 中。
        这里把 controller.yaml 加载到节点私有命名空间，使 offboard_control_node 内部的 private NodeHandle 可以读取
        ~control/rate、~takeoff/z、~topic/raw_setpoint 等参数。
    -->
    <node pkg="fastnav_control"
          type="offboard_control_node"
          name="fastnav_offboard_control_node"
          output="screen">
        <rosparam file="$(arg config_file)" command="load"/>
    </node>

    <!-- </launch> 结束根标签，表示本文件声明的参数加载和节点启动项到此结束。 -->
</launch>
